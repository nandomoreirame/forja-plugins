{
  "name": "forja-plugins",
  "version": "1.0.11",
  "private": true,
  "description": "Official plugin registry for Forja",
  "author": "Forja Team",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "build:registry": "node scripts/build-registry.mjs",
    "dev": "FORJA_WATCH=1 pnpm -r --parallel dev",
    "dev:plugin": "FORJA_WATCH=1 pnpm --filter",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "node scripts/validate-plugins.mjs"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.5",
    "vitest": "^3.1.1"
  }
}
